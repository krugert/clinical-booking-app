@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@* @inject IJSRuntime JSRuntime *@
@rendermode InteractiveWebAssembly
@using MudBlazor

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider /> 
<MudSnackbarProvider />

<div class="page">

    <main>

        <div class="top-row px-4">

            <MudAppBar Elevation="1">
                <MudText Typo="Typo.h6" Class="ml-3">Clinic Booking System</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/">Home</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/dashboard">Dashboard</MudButton>

                <MudButtonGroup Color="Color.Inherit" Variant="Variant.Text">
                    <MudButton>Account</MudButton>

                    <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown">

                        @if (isAuthenticated)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/profile">@username</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LogoutAsync">Logout</MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">Login</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/register">Register</MudButton>
                        }

                    </MudMenu>
                </MudButtonGroup>

            </MudAppBar>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
